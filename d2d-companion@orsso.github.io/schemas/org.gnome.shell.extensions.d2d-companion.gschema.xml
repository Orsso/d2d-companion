<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.shell.extensions.d2d-companion.profile">
    <value nick="subtle" value="0"/>
    <value nick="balanced" value="1"/>
    <value nick="expressive" value="2"/>
    <value nick="custom" value="3"/>
  </enum>

  <enum id="org.gnome.shell.extensions.d2d-companion.easing">
    <value nick="linear" value="0"/>
    <value nick="ease-out-quad" value="1"/>
    <value nick="ease-out-cubic" value="2"/>
    <value nick="ease-out-back" value="3"/>
  </enum>

  <enum id="org.gnome.shell.extensions.d2d-companion.press-mode">
    <value nick="launches-only" value="0"/>
    <value nick="all-primary-clicks" value="1"/>
  </enum>

  <enum id="org.gnome.shell.extensions.d2d-companion.press-effect">
    <value nick="squash" value="0"/>
    <value nick="dim" value="1"/>
  </enum>

  <enum id="org.gnome.shell.extensions.d2d-companion.launch-effect">
    <value nick="pulse" value="0"/>
    <value nick="bounce" value="1"/>
    <value nick="stretch" value="2"/>
    <value nick="stock" value="3"/>
  </enum>

  <schema id="org.gnome.shell.extensions.d2d-companion"
          path="/org/gnome/shell/extensions/d2d-companion/">
    <key name="motion-profile" enum="org.gnome.shell.extensions.d2d-companion.profile">
      <default>"subtle"</default>
      <summary>Current profile</summary>
    </key>

    <key name="custom-hover-enabled" type="b">
      <default>true</default>
      <summary>Use hover motion in Custom</summary>
    </key>
    <key name="custom-hover-scale" type="d">
      <default>1.16</default>
      <range min="1.0" max="1.30"/>
      <summary>Hover scale</summary>
    </key>
    <key name="custom-hover-lift" type="i">
      <default>2</default>
      <range min="0" max="12"/>
      <summary>Hover lift in pixels</summary>
    </key>
    <key name="custom-hover-duration" type="i">
      <default>160</default>
      <range min="50" max="500"/>
      <summary>Hover duration in milliseconds</summary>
    </key>
    <key name="custom-hover-easing" enum="org.gnome.shell.extensions.d2d-companion.easing">
      <default>"ease-out-cubic"</default>
      <summary>Hover transition easing</summary>
    </key>
    <key name="custom-neighbor-scale" type="d">
      <default>1.035</default>
      <range min="1.0" max="1.15"/>
      <summary>Neighbor scale</summary>
    </key>

    <key name="custom-press-enabled" type="b">
      <default>true</default>
      <summary>Use press feedback in Custom</summary>
    </key>
    <key name="custom-press-mode" enum="org.gnome.shell.extensions.d2d-companion.press-mode">
      <default>"all-primary-clicks"</default>
      <summary>Press feedback trigger</summary>
    </key>
    <key name="custom-press-effect" enum="org.gnome.shell.extensions.d2d-companion.press-effect">
      <default>"squash"</default>
      <summary>Press feedback effect</summary>
    </key>
    <key name="custom-press-intensity" type="d">
      <default>0.60</default>
      <range min="0.0" max="1.0"/>
      <summary>Press intensity</summary>
    </key>
    <key name="custom-press-duration" type="i">
      <default>110</default>
      <range min="50" max="300"/>
      <summary>Press duration in milliseconds</summary>
    </key>

    <key name="custom-launch-enabled" type="b">
      <default>true</default>
      <summary>Use launch animation in Custom</summary>
    </key>
    <key name="custom-launch-effect" enum="org.gnome.shell.extensions.d2d-companion.launch-effect">
      <default>"bounce"</default>
      <summary>Launch effect</summary>
    </key>
    <key name="custom-launch-intensity" type="d">
      <default>0.60</default>
      <range min="0.0" max="1.0"/>
      <summary>Launch effect intensity</summary>
    </key>
    <key name="custom-launch-speed" type="d">
      <default>1.0</default>
      <range min="0.50" max="2.0"/>
      <summary>Launch speed</summary>
    </key>
    <key name="custom-launch-repeat" type="b">
      <default>true</default>
      <summary>Repeat while starting</summary>
    </key>
    <key name="custom-launch-repeat-pause" type="i">
      <default>300</default>
      <range min="0" max="1000"/>
      <summary>Pause between launch repeats in milliseconds</summary>
    </key>
    <key name="custom-launch-max-duration" type="i">
      <default>10000</default>
      <range min="500" max="15000"/>
      <summary>Maximum launch repeat time in milliseconds</summary>
    </key>
    <key name="custom-bounce-decay" type="d">
      <default>0.0</default>
      <range min="0.0" max="1.0"/>
      <summary>Secondary bounce height</summary>
    </key>
    <key name="custom-pulse-count" type="i">
      <default>2</default>
      <range min="1" max="4"/>
      <summary>Pulse count</summary>
    </key>
    <key name="custom-stretch-elasticity" type="d">
      <default>0.70</default>
      <range min="0.0" max="1.0"/>
      <summary>Stretch effect elasticity</summary>
    </key>

    <key name="show-hover-background" type="b">
      <default>false</default>
      <summary>Show the hover background</summary>
      <description>When false, hide Dash to Dock's hover tile.</description>
    </key>

    <key name="show-focused-app-background" type="b">
      <default>false</default>
      <summary>Show the focused app background</summary>
      <description>When false, hide Dash to Dock's focused app tile.</description>
    </key>

    <key name="measured-hover-budget" type="d">
      <default>0.0</default>
      <range min="0.0" max="4096.0"/>
      <summary>Hover room in pixels</summary>
      <description>Measured from the live dock. 0 means unknown. Not a user setting.</description>
    </key>

    <key name="measured-icon-size" type="d">
      <default>0.0</default>
      <range min="0.0" max="4096.0"/>
      <summary>Measured dock icon size in pixels</summary>
      <description>Measured with the hover room. Not a user setting.</description>
    </key>
  </schema>
</schemalist>
